{
  "expo": {
    "name": "BudgetWise",
    "slug": "budgetwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/budgetwise-logo.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Receive weekly financial report summaries"
      }
    },
    "android": {
      "package": "com.limitsss.budgetwise",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/budgetwise-logo.png",
        "backgroundColor": "#0A1210"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/budgetwise-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/budgetwise-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1210"
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/budgetwise-logo.png",
          "color": "#1A4D2E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "755ea7e5-ca7c-4329-aecd-0281c9a43cde"
      }
    }
  }
}
